[Unit]
Description=Podman container-app.service
Documentation=man:podman-generate-systemd(1)
Wants=network-online.target
After=network-online.target
RequiresMountsFor=%t/containers

[Service]
Environment=PODMAN_SYSTEMD_UNIT=%n
Restart=always
TimeoutStopSec=70
ExecStartPre=/bin/rm -f %t/%n.ctr-id
ExecStart=/usr/bin/podman run \
  --cidfile=%t/%n.ctr-id \
  --cgroups=no-conmon \
  --sdnotify=conmon \
  --rm \
  --replace \
  --name service \
  -d \
  -p 443:443 \
  -p 80:80 \
  --label io.containers.autoupdate=registry \
  -v /cert/fullchain.pem:/cert/fullchain.pem:ro \
  -v /cert/privkey.pem:/cert/privkey.pem:ro \
  -e 'SSL_KEY_PATH=/cert/privkey.pem' \
  -e 'SSL_CERT_PATH=/cert/fullchain.pem' \
  -e 'LOGFLARE_API_KEY={{ builder_logflare_api_key }}' \
  -e 'LOGFLARE_SOURCE_ID={{ builder_logflare_source_id }}' \
  -e 'DATABASE_URL={{ database_url }}' \
  -e 'SECRET_KEY_BASE={{ builder_phx_secret }}' \
  {{ builder_container_registry }}/{{ builder_container_tag }}
ExecStop=/usr/bin/podman stop --ignore --cidfile=%t/%n.ctr-id
ExecStopPost=/usr/bin/podman rm -f --ignore --cidfile=%t/%n.ctr-id
Type=notify
NotifyAccess=all

[Install]
WantedBy=default.target
