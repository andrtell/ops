#!/bin/env bash

deps() {
  if ! type -p $1 &> /dev/null 
  then
      echo "'$1' must be installed to run this script."
      exit 126
  fi
}

deps "podman"

help() {
  cat <<_EOF
    manage release running inside container

    usage: 
      
      ectl <command> [<arg> ...]

    commands:

      remote      connect to the running system via a remote shell

      help        print help
_EOF
}

(( $# < 1 )) && {
    help
    exit 126
}

case "$1" in
    remote)
        podman exec -it {{ web_container_tag }} bin/tell remote
        ;;
    help)
        help
        ;;
    *)
        help
        exit 126
        ;;
esac
